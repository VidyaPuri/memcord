# Memcord — .env
# Copy to .env and fill in your values

# === REQUIRED ===
DISCORD_TOKEN=

# === LLM BACKEND (choose one) ===

# Option A: Claude Code CLI (requires: npm install -g @anthropic-ai/claude-code)
# MEMCORD_BACKEND=claude_code
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI API
# MEMCORD_BACKEND=openai
# OPENAI_API_KEY=sk-...
# MEMCORD_MODEL=gpt-4o

# Option C: Anthropic API (direct SDK)
# MEMCORD_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# MEMCORD_MODEL=claude-sonnet-4-20250514

# Option D: Ollama (local)
# MEMCORD_BACKEND=ollama
# MEMCORD_OLLAMA_URL=http://localhost:11434
# MEMCORD_MODEL=llama3

# Option E: Custom backend
# MEMCORD_BACKEND=custom
# MEMCORD_CUSTOM_BACKEND=mypackage.MyBackend

# === CACHE ===
# MEMCORD_EMBEDDING_MODEL=fast          # fast|accurate|tiny|multilingual|slovenian|labse (or HF model name)
# MEMCORD_SIMILARITY_THRESHOLD=0.80     # FAQ cache similarity (0-1)
# MEMCORD_ADAPTIVE_THRESHOLD=true       # Auto-tune threshold
# MEMCORD_FEEDBACK_THRESHOLD=0.80       # Feedback attribution threshold
# MEMCORD_DATA_DIR=./memcord_data       # ChromaDB + stats storage

# === RATE LIMITING ===
# MEMCORD_RATE_LIMIT=5                  # Max questions per window
# MEMCORD_RATE_WINDOW=60                # Window in seconds

# === CONTEXT ===
# MEMCORD_CONTEXT_MESSAGES=5            # Messages of conversation context
# MEMCORD_MAX_INPUT_LENGTH=2000         # Max input chars

# === OPERATIONS ===
# MEMCORD_LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR
# MEMCORD_TIMEOUT=60                    # LLM request timeout
# MEMCORD_RETRY_MAX=3                   # Max retries
# MEMCORD_RETRY_DELAY=1.0               # Initial retry delay (exponential backoff)
# MEMCORD_HEALTH_PORT=8080              # Health check HTTP port (0=disable)
# MEMCORD_METRICS_FILE=./memcord_data/metrics.json
