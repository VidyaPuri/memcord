# Memcord — .env
# Copy to .env and fill in your values

# === REQUIRED ===
DISCORD_TOKEN=

# === LLM BACKEND (choose one) ===

# Option A: Claude Code CLI
# Requires: npm install -g @anthropic-ai/claude-code
# MEMCORD_BACKEND=claude_code
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: OpenAI API
# MEMCORD_BACKEND=openai
# OPENAI_API_KEY=sk-...
# MEMCORD_MODEL=gpt-4o

# Option C: Anthropic API (direct SDK, no CLI needed)
# MEMCORD_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# MEMCORD_MODEL=claude-sonnet-4-20250514

# Option D: Ollama (local)
# MEMCORD_BACKEND=ollama
# MEMCORD_OLLAMA_URL=http://localhost:11434
# MEMCORD_MODEL=llama3

# === OPTIONAL ===
# MEMCORD_SIMILARITY_THRESHOLD=0.80     # FAQ cache similarity (0-1)
# MEMCORD_ADAPTIVE_THRESHOLD=true       # Auto-tune threshold
# MEMCORD_DATA_DIR=./memcord_data       # ChromaDB + stats storage
